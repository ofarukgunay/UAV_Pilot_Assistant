# ============================================
# IHA Pilot Asistani - Ortam Degiskenleri
# ============================================
# Bu dosyayi ".env" olarak kopyalayin ve kendi degerlerinizi girin.
# .env dosyasi git'e EKLENMEZ (.gitignore'da tanimli).

# --- LLM API Ayarlari ---
# Kullanmak istediginiz LLM'e gore doldurun.

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here

# Google Gemini
# GOOGLE_API_KEY=your-google-api-key-here

# Yerel Model (Ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- Genel Ayarlar ---
LOG_LEVEL=INFO
