# ============================================
# IHA Pilot Asistani - Ortam Degiskenleri
# ============================================
# Bu dosyayi ".env" olarak kopyalayin ve kendi degerlerinizi girin.
# .env dosyasi git'e EKLENMEZ (.gitignore'da tanimli).

# --- LLM API Ayarlari ---
# Kullanmak istediginiz LLM'e gore doldurun.

# Yerel Model (Ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- Web Dashboard Ayarlari ---
# Flask secret key - MUTLAKA degistirin!
FLASK_SECRET_KEY=guclu-ve-rastgele-bir-anahtar-buraya

# --- Genel Ayarlar ---
LOG_LEVEL=INFO
